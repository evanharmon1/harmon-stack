{
  "name": "Dev Container - {{ project_name }}",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu-24.04",
  "initializeCommand": "test -f .devcontainer/dev/devcontainer.env || touch .devcontainer/dev/devcontainer.env",
  "runArgs": [
    "--device=/dev/net/tun",
    "--env-file",
    ".devcontainer/dev/devcontainer.env"
  ],
  "features": {
    "ghcr.io/devcontainers/features/python:1": {
      "version": "3.13"
    },
    "ghcr.io/devcontainers/features/node:1": {
      "version": "22"
    },
    "ghcr.io/devcontainers/features/terraform:1": {
      "version": "latest",
      "tflint": "latest"
    },
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "dockerDashComposeVersion": "v2"
    },
    "ghcr.io/tailscale/codespace/tailscale": {},
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers-extra/features/go-task:1": {},
    "ghcr.io/itsmechlark/features/1password:1.5.0": {}
  },
  "mounts": [
    "source=claude-code-config-${devcontainerId},target=/home/vscode/.claude,type=volume",
    "source=codex-config-${devcontainerId},target=/home/vscode/.codex,type=volume",
    "source=gemini-config-${devcontainerId},target=/home/vscode/.gemini,type=volume"
  ],
  "remoteEnv": {
    "ANSIBLE_CONFIG": "${containerWorkspaceFolder}/ansible/ansible.cfg"
  },
  "postCreateCommand": "bash .devcontainer/dev/post-create.sh",
  "postStartCommand": "bash .devcontainer/dev/post-start.sh",
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.inheritEnv": true,
        "python.defaultInterpreterPath": ".venv/bin/python",
        "[python]": {
          "editor.defaultFormatter": "ms-python.black-formatter"
        },
        "debug.javascript.autoAttachFilter": "disabled",
        "terminal.integrated.env.linux": {
          "NODE_OPTIONS": ""
        }
      },
      "extensions": [
        "hashicorp.terraform",
        "redhat.ansible",
        "ms-azuretools.vscode-docker",
        "ms-python.python",
        "ms-python.black-formatter",
        "astro-build.astro-vscode",
        "timonwong.shellcheck",
        "redhat.vscode-yaml",
        "foxundermoon.shell-format",
        "GitHub.vscode-github-actions",
        "task.vscode-task",
        "EditorConfig.EditorConfig",
        "anthropic.claude-code",
        "openai.chatgpt"
      ]
    }
  },
  "remoteUser": "vscode",
  "updateRemoteUserUID": true,
  "forwardPorts": [4321],
  "portsAttributes": {
    "4321": {
      "label": "Astro Dev Server",
      "onAutoForward": "notify"
    }
  }
}
